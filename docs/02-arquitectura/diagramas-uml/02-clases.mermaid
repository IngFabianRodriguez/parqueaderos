%% Modelo de Clases — ParkCore
%% Plataforma de gestión de parqueaderos

classDiagram
    direction TB

    %% =========================================================================
    %% DOMINIO: Sede y Zonas
    %% =========================================================================
    class Sede {
        -String idSede
        -String nombre
        -String direccion
        -String ciudad
        -Integer capacidadTotal
        -Boolean activa
        +getIdSede() String
        +getNombre() String
        +setNombre(nombre) void
        +getCapacidadTotal() Integer
        +consultarDisponibilidad() Integer
        +agregarZona(zona) void
        +obtenerZonas() List~Zona~
    }

    class Zona {
        -String idZona
        -String nombre
        -TipoZona tipo
        -Integer capacidad
        -Sede sede
        +getIdZona() String
        +getCapacidad() Integer
        +setCapacidad(capacidad) void
        +obtenerEspacios() List~Espacio~
        +contarDisponibles() Integer
    }

    class Espacio {
        -String idEspacio
        -String codigo
        -EstadoEspacio estado
        -Zona zona
        +getIdEspacio() String
        +getCodigo() String
        +getEstado() EstadoEspacio
        +ocupar() void
        +liberar() void
    }

    %% =========================================================================
    %% DOMINIO: Vehículos y Registros
    %% =========================================================================
    class Vehiculo {
        -String idVehiculo
        -String placa
        -String marca
        -String modelo
        -String color
        -Boolean bloqueado
        -Cliente cliente
        +getIdVehiculo() String
        +getPlaca() String
        +setBloqueado(bloqueado) void
        +isBloqueado() Boolean
        +obtenerRegistros() List~RegistroEntrada~
    }

    class RegistroEntrada {
        -String idRegistro
        -DateTime fechaHoraEntrada
        -String imagenPlaca
        -Vehiculo vehiculo
        -Sede sede
        -Espacio espacioAsignado
        +getIdRegistro() String
        +getFechaHoraEntrada() DateTime
        +getVehiculo() Vehiculo
        +registrar() void
    }

    class RegistroSalida {
        -String idRegistroSalida
        -DateTime fechaHoraSalida
        -Integer duracionMinutos
        -RegistroEntrada registroEntrada
        -Pago pago
        +getIdRegistroSalida() String
        +getDuracionMinutos() Integer
        +calcularDuracion() Integer
        +registrar() void
    }

    %% =========================================================================
    %% DOMINIO: Pagos
    %% =========================================================================
    class Pago {
        -String idPago
        -BigDecimal monto
        -MetodoPago metodo
        -EstadoPago estado
        -DateTime fechaPago
        -RegistroEntrada registroEntrada
        -Cliente cliente
        +getIdPago() String
        +getMonto() BigDecimal
        +setEstado(estado) void
        +confirmar() Boolean
        +getFechaPago() DateTime
    }

    class PlanTarifario {
        -String idPlan
        -String nombre
        -BigDecimal precioBase
        -BigDecimal precioPorMinuto
        -BigDecimal precioPorHora
        -TipoPlan tipo
        +getIdPlan() String
        +getPrecioBase() BigDecimal
        +calcularMonto(duracionMinutos) BigDecimal
        +aplicarDescuento(monto) BigDecimal
    }

    %% =========================================================================
    %% DOMINIO: Clientes
    %% =========================================================================
    class Cliente {
        -String idCliente
        -String nombre
        -String telefono
        -String email
        -List~Vehiculo~ vehiculos
        -List~Pago~ pagos
        +getIdCliente() String
        +getNombre() String
        +agregarVehiculo(vehiculo) void
        +obtenerVehiculos() List~Vehiculo~
        +realizarPago(pago) void
    }

    %% =========================================================================
    %% DOMINIO: Dispositivos
    %% =========================================================================
    class Talanquera {
        -String idTalanquera
        -TipoTalanquera tipo
        -String ipDispositivo
        -EstadoTalanquera estado
        -Sede sede
        +getIdTalanquera() String
        +abrir() Boolean
        +cerrar() void
        +getEstado() EstadoTalanquera
        +enviarSenialApertura() void
    }

    class Notificacion {
        -String idNotificacion
        -TipoNotificacion tipo
        -String mensaje
        -DateTime fechaEnvio
        -Boolean leida
        -Cliente cliente
        +getIdNotificacion() String
        +enviar() void
        +marcarLeida() void
    }

    %% =========================================================================
    %% DOMINIO: Usuarios y Auth
    %% =========================================================================
    class Usuario {
        -String idUsuario
        -String nombre
        -String username
        -String passwordHash
        -Boolean activo
        -Rol rol
        -Sede sede
        +getIdUsuario() String
        +getUsername() String
        +autenticar(password) Boolean
        +tienePermiso(permiso) Boolean
    }

    class Rol {
        -String idRol
        -String nombre
        -List~String~ permisos
        +getIdRol() String
        +getNombre() String
        +agregarPermiso(permiso) void
        +tienePermiso(permiso) Boolean
    }

    %% =========================================================================
    %% RELACIONES — Composicion (◇──) y Asociacion (──)
    %% =========================================================================

    %% Sede → Zonas (composición)
    Sede "1" *-- "1..n" Zona : tiene

    %% Zona → Espacios (composición)
    Zona "1" *-- "1..n" Espacio : contiene

    %% Sede → RegistrosEntrada (composición)
    Sede "1" *-- "0..n" RegistroEntrada : registra entradas

    %% RegistroEntrada → Vehiculo (asociación)
    RegistroEntrada "1" --> "1" Vehiculo : pertenece

    %% RegistroSalida → RegistroEntrada (asociación)
    RegistroSalida "1" --> "1" RegistroEntrada : cierra

    %% RegistroEntrada → Pago (asociación)
    RegistroEntrada "1" --> "0..1" Pago : genera

    %% Cliente → Vehiculo (composición)
    Cliente "1" *-- "0..n" Vehiculo : posee

    %% Cliente → Pago (asociación)
    Cliente "1" --> "0..n" Pago : realiza

    %% PlanTarifario → Sede (asociación)
    PlanTarifario "1" --> "0..n" Sede : aplica a

    %% RegistroEntrada → Espacio (asociación opcional)
    RegistroEntrada "1" --> "0..1" Espacio : ocupa

    %% Talanquera → Sede (asociación)
    Talanquera "1" --> "0..1" Sede : pertenece

    %% Usuario → Rol (asociación)
    Usuario "1" --> "1" Rol : tiene

    %% Usuario → Sede (asociación opcional)
    Usuario "1" --> "0..1" Sede : administra

    %% Notificacion → Cliente (asociación)
    Notificacion "1" --> "0..1" Cliente : envia a