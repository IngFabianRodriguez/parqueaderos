%% Diagrama de Actividades — Flujo entrada-pago-salida
%% ParkCore: Proceso desde llegada hasta salida del vehículo

stateDiagram-v2
    [*] --> VerificandoEntrada

    %% =========================================================================
    %% ENTRADA
    %% =========================================================================
    state VerificandoEntrada {
        [*] --> PlacaLeida
        PlacaLeida --> PlacaIlegible: No legible

        PlacaIlegible --> RegistroManual: Operador digita
        RegistroManual --> PlacaLeida: Placa obtenida

        PlacaLeida --> [*]: Listo
    }

    VerificandoEntrada --> DisponibilidadSede: Placa OK

    state DisponibilidadSede {
        [*] --> ConsultandoBD
        ConsultandoBD --> HayPlazas: Espacios > 0
        ConsultandoBD --> SinPlazas: Capacidad = 0

        HayPlazas --> [*]: Espacios disponibles
        SinPlazas --> [*]: Parqueadero lleno
    }

    DisponibilidadSede --> AbrirTalanqueraEntrada: HayPlazas
    DisponibilidadSede --> NegarEntrada: SinPlazas

    AbrirTalanqueraEntrada --> VehiculoEstacionado: Barrera abierta
    NegarEntrada --> [*]: Fin — entrada negada

    VehiculoEstacionado --> ProcesandoPago: Cliente inicia pago

    %% =========================================================================
    %% PAGO
    %% =========================================================================
    state ProcesandoPago {
        [*] --> SolicitarMonto
        SolicitarMonto --> ClienteConfirma: Usuario confirma

        ClienteConfirma --> Procesando: Conectar pasarela
        Procesando --> PagoExitoso: Aprobado
        Procesando --> PagoFallido: Rechazado

        PagoFallido --> SolicitarMonto: Reintentar

        PagoExitoso --> [*]: Confirmado
    }

    ProcesandoPago --> AbrirTalanqueraSalida: PagoExitoso

    %% =========================================================================
    %% SALIDA
    %% =========================================================================
    AbrirTalanqueraSalida --> VehiculoSale: Barrera abierta
    VehiculoSale --> ActualizarBD: Registrar salida
    ActualizarBD --> [*]: Fin — proceso completo