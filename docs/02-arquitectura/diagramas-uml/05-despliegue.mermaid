%% Diagrama de Despliegue — Infraestructura ParkCore
%% Nodos de infraestructura y relaciones de comunicación

flowchart TB
    %% =========================================================================
    %% Estilos por tipo de nodo
    %% =========================================================================
    style Clientes fill:#2d4a22,stroke:#4a7c43,stroke-width:2px,color:#fff
    style Servidores fill:#1a1a4e,stroke:#3a3a8e,stroke-width:2px,color:#fff
    style Datos fill:#4e1a1a,stroke:#8e3a3a,stroke-width:2px,color:#fff
    style IoT fill:#4e3a1a,stroke:#8e6a3a,stroke-width:2px,color:#fff

    subgraph Clientes["🖥️ Clientes"]
        direction LR
        Browser["🌐 NavegadorWeb\n(Chrome/Firefox)\nFrontend SPA"]
        App["📱 App Móvil\n(iOS/Android)\nApp ParkCore"]
    end

    subgraph Servidores["🖧 Servidores — Docker/K8s"]
        direction LR
        APIGateway["🔐 APIGateway\nNode.js"]
        Microservicios["⚙️ Microservicios\n(Node.js/Python)"]
        ANPRService["📷 Servicio ANPR\nPython/TensorFlow"]
    end

    subgraph Datos["💾 Capa de Datos"]
        direction LR
        PostgreSQL["🗄️ PostgreSQL\n(AWS RDS)\nParkCore_DB\nRéplica Read"]
        Redis["⚡ Redis\n(ElastiCache)\nSessions\nDisponibilidad"]
        Mosquitto["📡 Mosquitto\nBroker MQTT\ntalanquera/#\nanpr/captures"]
    end

    subgraph IoT["📡 Dispositivos en Sede"]
        direction LR
        CamaraIP["📷 Cámara ANPR\n(IP)"]
        TalanqueraPLC["🚧 Controladora\nTalanquera PLC"]
        Sensores["📊 Sensores IoT\n(Ocupación)"]
        EdgeGateway["🌐 Edge Gateway\nMQTT Bridge\nEdge Agent"]
    end

    %% =========================================================================
    %% Relaciones cliente → servidor
    %% =========================================================================
    Browser -->|HTTPS/WSS| APIGateway
    App -->|HTTPS/MQTT| APIGateway

    %% =========================================================================
    %% Relaciones API → microservicios
    %% =========================================================================
    APIGateway -->|gRPC/REST| Microservicios
    APIGateway -->|gRPC| ANPRService

    %% =========================================================================
    %% Relaciones con datos
    %% =========================================================================
    Microservicios -->|JDBC/PostgreSQL| PostgreSQL
    Microservicios -->|Redis| Redis
    APIGateway -->|MQTT| Mosquitto

    %% =========================================================================
    %% Relaciones MQTT broker → edge
    %% =========================================================================
    Mosquitto -.->|MQTT| EdgeGateway

    %% =========================================================================
    %% Relaciones edge → dispositivos IoT
    %% =========================================================================
    EdgeGateway -->|RTSP| CamaraIP
    EdgeGateway -->|Modbus/TCP| TalanqueraPLC
    EdgeGateway -->|HTTP| Sensores

    %% =========================================================================
    %% Notas
    %% =========================================================================
    ANPRService -.->|RTSP| CamaraIP : streaming video