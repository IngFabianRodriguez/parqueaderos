%% Diagrama de Casos de Uso — ParkCore
%% Plataforma de gestión de parqueaderos

%% Configuración
不开图表方向
%% =============

%% Actores del sistema
actor Cliente <<Cliente (conductor)>>
actor Operador
actor AdminSede <<Administrador de Sede>>
actor AdminGlobal <<Administrador Global>>
actor SistemaANPR <<Sistema ANPR>>

%% Casos de Uso — Agrupa por funcionalidad
rect rgb(40, 40, 80)
    note "Gestión de Entrada/Salida" as N1
    usecase UC1 as "Consultar disponibilidad"
    usecase UC2 as "Registrar entrada ANPR"
    usecase UC3 as "Registrar salida ANPR"
    usecase UC6 as "Abrir talanquera"
end rect

rect rgb(50, 70, 50)
    note "Pagos" as N2
    usecase UC4 as "Realizar pago"
    usecase UC5 as "Validar pago"
end rect

rect rgb(70, 50, 50)
    note "Administración" as N3
    usecase UC7 as "Gestionar tarifas"
    usecase UC8 as "Bloquear placa moroso"
    usecase UC9 as "Ver dashboard"
    usecase UC10 as "Gestionar usuarios y roles"
end rect

rect rgb(50, 50, 70)
    note "Consultas" as N4
    usecase UC11 as "Recibir notificaciones"
    usecase UC12 as "Consultar historial por placa"
end rect

%% Relaciones Actor → Caso de Uso
Cliente --> UC1
Cliente --> UC2
Cliente --> UC3
Cliente --> UC4
Cliente --> UC11

Operador --> UC1
Operador --> UC6
Operador --> UC7

AdminSede --> UC7
AdminSede --> UC8
AdminSede --> UC9
AdminSede --> UC10

AdminGlobal --> UC9
AdminGlobal --> UC10

SistemaANPR --> UC2
SistemaANPR --> UC3