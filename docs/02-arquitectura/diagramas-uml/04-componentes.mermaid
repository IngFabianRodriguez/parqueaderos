%% Diagrama de Componentes — Arquitectura de alto nivel ParkCore
%% Plataforma de gestión de parqueaderos

flowchart LR
    %% =========================================================================
    %% Estilos
    %% =========================================================================
    style CapaPresentacion fill:#1a1a2e,stroke:#16213e,stroke-width:2px,color:#eee
    style CapaNegocio fill:#1a1a2e,stroke:#16213e,stroke-width:2px,color:#eee
    style CapaDatos fill:#1a1a2e,stroke:#16213e,stroke-width:2px,color:#eee
    style DispositivosIoT fill:#1a1a2e,stroke:#16213e,stroke-width:2px,color:#eee

    %% =========================================================================
    %% Capa de Presentación
    %% =========================================================================
    subgraph CapaPresentacion["🔲 Capa de Presentación"]
        direction TB
        ClienteWeb["🌐 ClienteWeb"]
        AppMovil["📱 AppMovil"]
    end

    %% =========================================================================
    %% Capa de Negocio
    %% =========================================================================
    subgraph CapaNegocio["⚙️ Capa de Negocio"]
        direction LR
        APIGateway["🔐 APIGateway"]
        ServicioANPR["📷 ServicioANPR"]
        ServicioDisponibilidad["📊 ServicioDisponibilidad"]
        ServicioPagos["💳 ServicioPagos"]
        ServicioTalanquera["🚧 ServicioTalanquera"]
        ServicioNotificaciones["🔔 ServicioNotificaciones"]
    end

    %% =========================================================================
    %% Capa de Datos
    %% =========================================================================
    subgraph CapaDatos["💾 Capa de Datos"]
        direction LR
        PostgreSQL["🗄️ PostgreSQL\nBase de Datos"]
        Redis["⚡ Redis\nCache"]
        BrokerMQTT["📡 BrokerMQTT"]
    end

    %% =========================================================================
    %% Dispositivos IoT
    %% =========================================================================
    subgraph DispositivosIoT["📱 Dispositivos IoT"]
        direction LR
        CamaraANPR["📷 Cámara ANPR"]
        TalanqueraElectronica["🚧 Talanquera\nElectrónica"]
        SensorOcupacion["📊 Sensor\nOcupación"]
        GatewayMQTT["🌐 GatewayMQTT\nLocal"]
    end

    %% =========================================================================
    %% Flechas: Presentación → Negocio
    %% =========================================================================
    ClienteWeb --> APIGateway : HTTPS REST
    AppMovil --> APIGateway : HTTPS REST

    %% =========================================================================
    %% Flechas: Negocio → Negocio (interno)
    %% =========================================================================
    APIGateway --> ServicioANPR : gRPC
    APIGateway --> ServicioDisponibilidad : REST
    APIGateway --> ServicioPagos : REST
    APIGateway --> ServicioTalanquera : MQTT
    APIGateway --> ServicioNotificaciones : REST

    %% =========================================================================
    %% Flechas: Negocio → Datos
    %% =========================================================================
    APIGateway --> PostgreSQL : JDBC
    APIGateway --> Redis : Redis Protocol
    ServicioPagos --> BrokerMQTT : Publish
    ServicioTalanquera --> BrokerMQTT : Subscribe
    ServicioNotificaciones --> BrokerMQTT : Publish

    %% =========================================================================
    %% Flechas: IoT → Datos / Negocio
    %% =========================================================================
    ServicioANPR --> CamaraANPR : RTSP
    ServicioDisponibilidad --> SensorOcupacion : HTTP
    ServicioTalanquera -.MQTT.-> TalanqueraElectronica : Señal abrir
    BrokerMQTT -.MQTT.-> GatewayMQTT : Bridge
    GatewayMQTT --> CamaraANPR : RTSP
    GatewayMQTT --> TalanqueraElectronica : Modbus