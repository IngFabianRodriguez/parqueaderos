%% Diagrama de Estados — Ciclo de vida de un vehículo
%% ParkCore: Estados desde llegada hasta salida definitiva

stateDiagram-v2
    direction TB

    %% =========================================================================
    %% Estados principales
    %% =========================================================================

    [*] --> Fuera

    Fuera --> EntradaDetectada: Sensor/cámara\ndetecta vehículo

    EntradaDetectada --> PlacaVerificada: OCR exitoso

    PlacaVerificada --> AbriendoTalanquera: Espacio asignado

    AbriendoTalanquera --> Estacionado: Vehículo dentro

    state Estacionado {
        [*] --> EstacionadoNormal
        EstacionadoNormal --> EstacionadoNormal: Vehículo\npermanece

        note: "El vehículo está dentro del parqueadero\nocupando un espacio"
    end

    Estacionado --> Pagando: Cliente inicia pago

    state Pagando {
        [*] --> EsperandoConfirmacion
        EsperandoConfirmacion --> Confirmado: Pasarela\naprueba
        EsperandoConfirmacion --> Rechazado: Pasarela\nrechaza

        Rechazado --> [*]: Reintentar

        Confirmado --> [*]: Listo
    end

    Pagando --> AbriendoTalanqueraSalida: Pagado

    AbriendoTalanqueraSalida --> Fuera: Vehículo sale

    Fuera --> [*]: Ciclo completo

    %% =========================================================================
    %% Estados de error/bloqueo
    %% =========================================================================
    state Fuera {
        [*] --> FueraNormal
        FueraNormal --> Bloqueado: Admin bloquea\nplaca morosa

        Bloqueado --> FueraNormal: Admin desbloquea

        note: "Si el vehículo está bloqueado,\nel sistema niega la entrada"
    end

    %% =========================================================================
    %% Transiciones de error en entrada
    %% =========================================================================
    EntradaDetectada --> Fuera: Placa no legible\n(no se puede registrar)
    PlacaVerificada --> Fuera: Vehículo bloqueado\n(placa morosa)