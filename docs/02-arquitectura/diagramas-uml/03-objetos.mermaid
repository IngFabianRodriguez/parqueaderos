%% Diagrama de Objetos — Escenario: Vehículo ABC-123 ingresa, paga y sale
%% ParkCore — Instancias del dominio

classDiagram
    direction TB

    %% =========================================================================
    %% Instancias concretas
    %% =========================================================================

    class sedeCentro {
        idSede = "S001"
        nombre = "Parqueadero Centro"
        direccion = "Av. Principal 123"
        ciudad = "Bogotá"
        capacidadTotal = 200
    }

    class zonaA {
        idZona = "Z001"
        nombre = "Zona A — Cubierta"
        tipo = "CUBIERTA"
        capacidad = 100
    }

    class espacio12 {
        idEspacio = "E012"
        codigo = "A-12"
        estado = "OCUPADO"
    }

    class vehiculoABC123 {
        idVehiculo = "V001"
        placa = "ABC-123"
        marca = "Toyota"
        modelo = "Corolla"
        color = "Gris"
        bloqueado = false
    }

    class regEntrada1 {
        idRegistro = "RE001"
        fechaHoraEntrada = "2026-05-07 10:30:00"
        imagenPlaca = "re001_placa.jpg"
    }

    class pago001 {
        idPago = "P001"
        monto = 15000.00
        metodo = "TARJETA_CREDITO"
        estado = "CONFIRMADO"
        fechaPago = "2026-05-07 12:45:00"
    }

    class talanquera1 {
        idTalanquera = "T001"
        tipo = "ENTRADA"
        ipDispositivo = "192.168.1.101"
        estado = "CERRADO"
    }

    class clienteJuan {
        idCliente = "C001"
        nombre = "Juan Pérez"
        telefono = "+57 300 123 4567"
        email = "juan.perez@email.com"
    }

    %% =========================================================================
    %% Relaciones entre objetos (instancias)
    %% =========================================================================
    sedeCentro *-- zonaA : tiene
    zonaA *-- espacio12 : contiene
    espacio12 ..> vehiculoABC123 : ocupado por

    regEntrada1 --> vehiculoABC123 : registra vehículo
    regEntrada1 --> espacio12 : asigna espacio
    regEntrada1 --> sedeCentro : registrado en

    pago001 --> regEntrada1 : corresponde a
    pago001 --> clienteJuan : realizado por

    talanquera1 --> sedeCentro : pertenece a

    clienteJuan ..> vehiculoABC123 : posee

    %% Nota del escenario
    note for sedeCentro "Escenario: Juan llega con su Toyota ABC-123.\nRegistra entrada en espacio A-12. Paga $15.000.\nLa talanquera abre y el vehículo sale."