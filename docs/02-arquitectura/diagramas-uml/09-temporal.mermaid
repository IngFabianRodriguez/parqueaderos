%% Diagrama Temporal (Gantt) — Flujo de salida ParkCore
%% Timing crítico: entrada → procesamiento → apertura < 1 segundo

gantt
    title Flujo de Salida — Timing de Apertura de Talanquera
    dateFormat X
    axisFormat %S.%L s

    section Cliente
    Llega a la salida           :done,    0.000, 0.200s

    section Cámara ANPR
    Detección de movimiento     :done,    0.000, 0.050s
    Captura imagen placa        :done,    0.050, 0.150s
    OCR procesamiento           :done,    0.150, 0.300s

    section Sistema
    Consulta BD por placa       :active,  0.300, 0.150s
    Validar pago confirmado     :crit,    0.450, 0.100s
    Registrar salida (RS-001)   :crit,    0.550, 0.100s
    Publicar señal MQTT          :crit,    0.650, 0.050s

    section Talanquera
    Recibir comando MQTT        :crit,    0.700, 0.050s
    Abrir relé/talanquera       :crit,    0.750, 0.150s

    section Cliente
    Barrera levantada           :done,    0.900, 0.100s
    Vehículo sale               :done,    1.000, 1.000s

    section Meta
    Objetivo total < 1s        :milestone, 1.000, 0s